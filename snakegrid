#!/usr/bin/env bash
# ─── snakegrid ───────────────────────────────────────────────────────────────
# Control the Hyprland snake-grid layout (a "snake" floating grid across desktops).
#
#   snakegrid               toggle the grid on/off for this session
#   snakegrid --always-on   start it automatically at every login
#   snakegrid --always-off  stop auto-starting it at login (and turn it off now)
#   snakegrid --help        show this help
#
MARK="$HOME/.config/hypr/.snakegrid-autostart"   # presence = start at login
STATE="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/snakegrid.state"

# Locate the daemon: honour $SNAKE_DAEMON, else the copy sitting next to this
# script FIRST, then the usual installed spots. Checking "next to me" first means
# running straight from a git checkout always uses that checkout's daemon — not a
# stale copy left in ~/.config from an earlier install. When installed,
# ~/.local/bin/snakegrid is a symlink into ~/.config/hypr/scripts, and readlink -f
# resolves it, so "$self" IS the install dir — installed users are unaffected.
find_daemon() {
    if [ -n "$SNAKE_DAEMON" ]; then printf '%s\n' "$SNAKE_DAEMON"; return; fi
    local self; self="$(dirname "$(readlink -f "$0")")"
    local cand
    for cand in \
        "$self/snake-grid.py" \
        "$HOME/.config/hypr/scripts/snake-grid.py" \
        "/usr/lib/snakegrid/snake-grid.py" \
        "/usr/share/snakegrid/snake-grid.py"; do
        [ -f "$cand" ] && { printf '%s\n' "$cand"; return; }
    done
}
DAEMON="$(find_daemon)"

# Match the daemon precisely so we never touch an editor or this very shell that
# merely has "snake-grid.py" somewhere on its command line.
running() { pgrep -f 'python3 .*snake-grid\.py' >/dev/null 2>&1; }

start() {
    if [ -z "$DAEMON" ]; then say "daemon not found — run ./install.sh"; return 1; fi
    running || setsid -f python3 "$DAEMON" >/dev/null 2>&1
}

stop() {
    pkill -f 'python3 .*snake-grid\.py' 2>/dev/null
    # return only the windows WE managed to normal tiling (recorded in $STATE).
    # The "|| [ -n "$addr" ]" makes the loop process a final line that has no
    # trailing newline — otherwise the last (newest) managed window is skipped and
    # left floating after teardown.
    if [ -f "$STATE" ]; then
        while IFS= read -r addr || [ -n "$addr" ]; do
            [ -n "$addr" ] && hyprctl dispatch settiled "address:$addr" >/dev/null 2>&1
        done < "$STATE"
        rm -f "$STATE"
    fi
}

say() { notify-send "snakegrid" "$1" -t 2200 2>/dev/null; echo "snakegrid: $1"; }

case "${1:-}" in
    "")
        if running; then stop; say "OFF for this session"; else start && say "ON for this session"; fi ;;
    --always-on)
        touch "$MARK"; start && say "ALWAYS-ON — it will start at every login" ;;
    --always-off)
        rm -f "$MARK"; stop; say "ALWAYS-OFF — it won't start at login" ;;
    --help|-h)
        cat <<'EOF'
snakegrid — Hyprland snake-grid layout (a "snake" floating grid across desktops)

  snakegrid               toggle the grid on/off for this session
  snakegrid --always-on   start it automatically at every login
  snakegrid --always-off  stop auto-starting it at login (and turn it off now)
  snakegrid --help        show this help

Tune it with environment variables (see the daemon's CONFIG block / README):
  SNAKE_WS=1,2  SNAKE_GRID=2x2  SNAKE_GAP=10  SNAKE_TOL=2  SNAKE_IGNORE=class1,class2
EOF
        ;;
    *)
        echo "snakegrid: unknown option '$1'  (try: snakegrid --help)"; exit 1 ;;
esac
